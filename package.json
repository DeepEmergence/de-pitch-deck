{
  "name": "de-pitch-deck",
  "private": true,
  "version": "1.0.0",
  "description": "DeepEmergence markdown pitch deck (Slidev) with editable Mermaid diagrams.",
  "scripts": {
    "dev": "slidev slides.md --open",
    "build": "slidev build slides.md",
    "build:html": "node scripts/build-html.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "export": "slidev export slides.md --format pptx --output DeepEmergence-Pitch-Deck.pptx",
    "export:pdf": "slidev export slides.md --format pdf --output DeepEmergence-Pitch-Deck.pdf"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "^0.25.0",
    "marked": "^18.0.5",
    "playwright-chromium": "^1.47.0"
  }
}
